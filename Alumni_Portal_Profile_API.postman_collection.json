                  "});",
                  "",
                  "pm.test('Upload successful', function () {",
                  "    const responseJson = pm.response.json();",
                  "    pm.expect(responseJson.success).to.be.true;",
                  "    pm.expect(responseJson).to.have.property('url');",
                  "});",
                  "",
