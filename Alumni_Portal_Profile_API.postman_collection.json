{
  "info": {
    "name": "Alumni Portal - Profile Management API",
    "description": "Complete API collection for Student and Alumni profile management",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8000/api",
      "type": "string"
    },
    {
      "key": "jwt_token",
      "value": "your_jwt_token_here",
      "type": "string"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{jwt_token}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Set Authorization header for all requests",
          "if (pm.variables.get('jwt_token')) {",
          "    pm.request.headers.add({",
          "        key: 'Authorization',",
          "        value: 'JWT ' + pm.variables.get('jwt_token')",
          "    });",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Student Profile",
      "item": [
        {
          "name": "Get Student Profile",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/student/profile/",
              "host": ["{{baseUrl}}"],
              "path": ["student", "profile", ""]
            },
            "description": "Retrieve the current user's student profile"
          },
          "response": [
            {
              "name": "Success Response",
              "originalRequest": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/student/profile/",
                  "host": ["{{baseUrl}}"],
                  "path": ["student", "profile", ""]
                }
              },
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "cookie": [],
              "body": "{\n  \"id\": 1,\n  \"first_name\": \"John\",\n  \"last_name\": \"Doe\",\n  \"program\": \"btech\",\n  \"current_semester\": 6,\n  \"batch_year\": 2021,\n  \"cgpa\": 8.5,\n  \"bio\": \"Passionate about software development and AI\",\n  \"profile_picture\": \"https://example.com/media/profiles/john_doe.jpg\",\n  \"phone\": \"+1-555-123-4567\",\n  \"location\": \"San Francisco, CA\",\n  \"technical_skills\": [\"JavaScript\", \"Python\", \"React\", \"Django\"],\n  \"soft_skills\": [\"Communication\", \"Leadership\", \"Problem Solving\"],\n  \"interests\": [\"AI/ML\", \"Web Development\", \"Startup\"],\n  \"career_goals\": \"Become a software engineer at a tech company\",\n  \"preferred_job_types\": [\"full_time\", \"internship\"],\n  \"preferred_locations\": [\"San Francisco, CA\", \"Remote\"],\n  \"has_internship_experience\": true,\n  \"internship_details\": \"3-month internship at TechCorp as a software developer\",\n  \"certifications\": [\"AWS Cloud Practitioner\", \"Google Analytics\"],\n  \"academic_achievements\": \"Dean's List, Best Project Award\",\n  \"major_coursework\": [\"Data Structures\", \"Algorithms\", \"Web Development\"],\n  \"extracurricular_activities\": \"Tech Club President, Hackathon Winner\",\n  \"expected_graduation\": \"2024-05-15\",\n  \"is_public\": true,\n  \"created_at\": \"2024-01-15T10:30:00Z\",\n  \"updated_at\": \"2024-01-20T14:22:00Z\"\n}"
            }
          ],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has profile data', function () {",
                  "    const responseJson = pm.response.json();",
                  "    pm.expect(responseJson).to.have.property('id');",
                  "    pm.expect(responseJson).to.have.property('first_name');",
                  "    pm.expect(responseJson).to.have.property('last_name');",
                  "});",
                  "",
                  "pm.test('Response time is acceptable', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Student Profile (JSON)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"first_name\": \"John\",\n  \"last_name\": \"Doe\",\n  \"program\": \"btech\",\n  \"current_semester\": 6,\n  \"batch_year\": 2021,\n  \"cgpa\": 8.5,\n  \"bio\": \"Passionate about software development and AI\",\n  \"phone\": \"+1-555-123-4567\",\n  \"location\": \"San Francisco, CA\",\n  \"technical_skills\": [\"JavaScript\", \"Python\", \"React\"],\n  \"soft_skills\": [\"Communication\", \"Leadership\"],\n  \"interests\": [\"AI/ML\", \"Web Development\"],\n  \"career_goals\": \"Become a software engineer at a tech company\",\n  \"preferred_job_types\": [\"full_time\", \"internship\"],\n  \"preferred_locations\": [\"San Francisco, CA\", \"Remote\"],\n  \"has_internship_experience\": true,\n  \"internship_details\": \"3-month internship at TechCorp\",\n  \"certifications\": [\"AWS Cloud Practitioner\"],\n  \"academic_achievements\": \"Dean's List\",\n  \"major_coursework\": [\"Data Structures\", \"Algorithms\"],\n  \"extracurricular_activities\": \"Tech Club President\",\n  \"expected_graduation\": \"2024-05-15\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/student/profile/",
              "host": ["{{baseUrl}}"],
              "path": ["student", "profile", ""]
            },
            "description": "Create a new student profile with JSON data"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Profile created successfully', function () {",
                  "    const responseJson = pm.response.json();",
                  "    pm.expect(responseJson).to.have.property('id');",
                  "    pm.expect(responseJson.first_name).to.eql('John');",
                  "    pm.expect(responseJson.last_name).to.eql('Doe');",
                  "});",
                  "",
                  "// Store profile ID for other requests",
                  "if (pm.response.code === 201) {",
                  "    const responseJson = pm.response.json();",
                  "    pm.environment.set('student_profile_id', responseJson.id);",
                  "}"
                ]
              }
            }
          ]
        },
